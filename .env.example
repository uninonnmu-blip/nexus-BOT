# Required: your bot's token from the Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Optional: command prefix (defaults to ",")
PREFIX=,

# Optional: comma-separated Discord user IDs that should ALWAYS be treated as bot owners.
# Anyone with the "Administrator" permission in their server can already use admin commands,
# so you only need this if you want admin access without giving yourself the Discord Admin role
# (e.g. for the bot developer to debug across servers). Leave blank to skip.
OWNER_IDS=
